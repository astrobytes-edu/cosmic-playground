---
import TagPill from "./TagPill.astro";
import TopicIcon from "./TopicIcon.astro";
import DemoIllustration from "./DemoIllustration.astro";
import { topicColor, primaryTopic } from "../lib/topicColors";

export type DemoCardProps = {
  title: string;
  slug: string;
  href: string;
  description?: string;
  status: "stable" | "beta" | "draft";
  readiness: "stub" | "experimental" | "candidate" | "launch-ready";
  topics: string[];
  levels: string[];
  timeMinutes: number;
  hasMathMode: boolean;
  keyIdea?: string;
  omoSummary?: string;
  playHref?: string;
  stationHref?: string;
  instructorHref?: string;
  playlistCount?: number;
  playlistHref?: string;
};

const {
  title,
  slug,
  href,
  description = "\u2014",
  status,
  readiness,
  topics,
  levels,
  timeMinutes,
  hasMathMode,
  keyIdea,
  omoSummary,
  playHref,
  stationHref,
  instructorHref,
  playlistCount = 0,
  playlistHref
} = Astro.props as DemoCardProps;

const topic = primaryTopic(topics);
const color = topicColor(topic);
const statusTone =
  status === "stable" ? "teal" : status === "beta" ? "status-beta" : "status-draft";
const readinessTone =
  readiness === "launch-ready"
    ? "teal"
    : readiness === "candidate"
      ? "violet"
      : readiness === "experimental"
        ? "status-beta"
        : "status-draft";
const readinessLabel =
  readiness === "launch-ready"
    ? "launch-ready"
    : readiness === "candidate"
      ? "candidate"
      : readiness === "experimental"
        ? "experimental"
        : "stub";
const timeLabel =
  timeMinutes <= 10 ? "\u226410 min" : timeMinutes <= 20 ? "10\u201320 min" : "20+ min";
---

<article class="demo-card cp-card" style={`--topic-color: ${color}`}>
  <div class="demo-card__top">
    <a class="demo-card__illustration-link" href={href} aria-label={`Open exhibit: ${title}`}>
      <div class="demo-card__illustration">
        <DemoIllustration slug={slug} />
      </div>
    </a>
    <div class="demo-card__body">
      <h3 class="demo-card__title">
        <a href={href}>{title}</a>
      </h3>
      {omoSummary ? (
        <p class="demo-card__key-line">
          <strong>Observable -&gt; Model -&gt; Inference:</strong> {omoSummary}
        </p>
      ) : (
        <p class="demo-card__key-line">
          <strong>Key idea:</strong> {keyIdea ?? description}
        </p>
      )}
      <p class="demo-card__desc">{description}</p>
      <div class="demo-card__badges" aria-label="Tags">
        <TagPill label={status} tone={statusTone} />
        <TagPill label={`readiness: ${readinessLabel}`} tone={readinessTone} />
        {topics.map((t) => (
          <TagPill label={t} tone="blue">
            <TopicIcon slot="icon" topic={t} />
          </TagPill>
        ))}
        <TagPill label={timeLabel} tone="default" />
        {levels.map((l) => <TagPill label={l} tone="default" />)}
        {hasMathMode ? <TagPill label="math mode" tone="violet" /> : null}
      </div>
    </div>
  </div>
  <div class="demo-card__actions">
    {playHref ? (
      <a class="cp-button cp-button--primary" href={playHref}>Play</a>
    ) : null}
    {stationHref ? (
      <a class="cp-button cp-button--ghost" href={stationHref}>Station card</a>
    ) : null}
    {instructorHref ? (
      <a class="cp-button cp-button--ghost" href={instructorHref}>Instructor notes</a>
    ) : null}
    {playlistCount > 0 && playlistHref ? (
      <a class="cp-chip demo-card__playlist-chip" href={playlistHref}>
        In {playlistCount} playlist{playlistCount === 1 ? "" : "s"}
      </a>
    ) : null}
  </div>
  <a class="demo-card__exhibit-link" href={href}>
    Open exhibit
  </a>
</article>

<style>
  .demo-card {
    border-radius: var(--cp-r-3);
    overflow: clip;
    transition:
      transform 200ms var(--cp-ease-out),
      box-shadow 200ms var(--cp-ease-out),
      border-color 200ms var(--cp-ease-out);
  }

  .demo-card:hover {
    transform: translateY(-4px);
    box-shadow:
      var(--cp-card-shadow-hover),
      0 0 24px color-mix(in srgb, var(--topic-color) 12%, transparent);
    border-color: color-mix(in srgb, var(--topic-color) 35%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .demo-card {
      transition: none;
    }
    .demo-card:hover {
      transform: none;
    }
  }

  .demo-card__top {
    display: grid;
  }

  .demo-card__illustration-link {
    display: block;
  }

  .demo-card__illustration {
    padding: var(--cp-space-3);
    background:
      radial-gradient(
        ellipse 80% 70% at 50% 50%,
        color-mix(in srgb, var(--topic-color) 8%, transparent) 0%,
        transparent 70%
      );
    border-bottom: 1px solid var(--cp-border-subtle);
    opacity: 0.85;
    transition: opacity 200ms var(--cp-ease-out);
  }

  .demo-card:hover .demo-card__illustration {
    opacity: 1;
  }

  .demo-card__body {
    padding: var(--cp-space-4);
    display: grid;
    gap: var(--cp-space-2);
  }

  .demo-card__title {
    margin: 0;
    font-size: var(--cp-text-xl);
    transition: color 200ms var(--cp-ease-out);
  }

  .demo-card__title a {
    color: var(--cp-title);
    text-decoration: none;
  }

  .demo-card__key-line {
    margin: 0;
    color: var(--cp-text);
    font-size: var(--cp-text-sm);
    line-height: 1.45;
  }

  .demo-card:hover .demo-card__title {
    color: var(--cp-title-strong);
  }

  .demo-card:hover .demo-card__title a {
    color: var(--cp-title-strong);
  }

  .demo-card__desc {
    margin: 0;
    color: var(--cp-text2);
    max-width: 72ch;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .demo-card__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    opacity: 0.9;
    margin-top: var(--cp-space-1);
  }

  .demo-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    padding: 0 var(--cp-space-4) var(--cp-space-4);
  }

  .demo-card__actions .cp-button {
    font-size: var(--cp-text-sm);
    padding: 6px 10px;
  }

  .demo-card__playlist-chip {
    margin-left: auto;
  }

  .demo-card__exhibit-link {
    display: inline-block;
    margin: 0 var(--cp-space-4) var(--cp-space-4);
    font-size: var(--cp-text-sm);
    color: var(--cp-accent-ice);
  }
</style>
