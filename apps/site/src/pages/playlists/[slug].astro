---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import TagPill from "../../components/TagPill.astro";
import { normalizeBasePathPath } from "../../lib/catalog";

export async function getStaticPaths() {
  const playlists = await getCollection("playlists");
  return playlists.map((playlist) => ({
    params: { slug: playlist.slug },
    props: { playlist }
  }));
}

const { playlist } = Astro.props;
const base = import.meta.env.BASE_URL;
const withBase = (path: string) => normalizeBasePathPath(path, base);

const demos = await getCollection("demos");
const demoBySlug = new Map<string, (typeof demos)[number]>(demos.map((d) => [d.slug, d]));

const resolved = playlist.data.demos
  .map((item) => ({ item, entry: demoBySlug.get(item.slug) }))
  .filter((row) => row.entry);

const requiredCount = resolved.filter((row) => row.item.required).length;
const optionalCount = resolved.length - requiredCount;

const { Content } = await playlist.render();
---

<Layout title={`${playlist.data.title} — Playlist`}>
  <Breadcrumb
    crumbs={[
      { label: "Playlists", href: withBase("playlists/") },
      { label: playlist.data.title }
    ]}
    withBase={withBase}
  />

  <header class="playlist-header cp-hero">
    <h1>{playlist.data.title}</h1>
    <p class="playlist-header__goal">{playlist.data.learning_goal}</p>
    <div class="playlist-header__meta">
      <TagPill label={playlist.data.audience} tone="blue" />
      <TagPill label={`Level ${playlist.data.intended_level.toUpperCase()}`} tone="violet" />
      <span class="playlist-header__stat">
        <span class="playlist-header__stat-value">{resolved.length}</span>
        <span class="playlist-header__stat-unit">demos</span>
      </span>
      <span class="playlist-header__stat">
        <span class="playlist-header__stat-value">~{playlist.data.estimated_minutes}</span>
        <span class="playlist-header__stat-unit">min</span>
      </span>
      <span class="playlist-header__stat">
        <span class="playlist-header__stat-value">{requiredCount}</span>
        <span class="playlist-header__stat-unit">required</span>
      </span>
      {optionalCount > 0 && (
        <span class="playlist-header__stat">
          <span class="playlist-header__stat-value">{optionalCount}</span>
          <span class="playlist-header__stat-unit">optional</span>
        </span>
      )}
    </div>
    <p class="playlist-header__overview">{playlist.data.overview}</p>
    <div class="playlist-header__actions">
      <a class="cp-button cp-button--ghost" href={withBase("playlists/")}>Browse all playlists</a>
      <a class="cp-button cp-button--ghost" href={withBase("explore/")}>Back to Explore</a>
    </div>
  </header>

  <section class="playlist-instructions" aria-label="Instructions">
    <h2>Instructions</h2>
    <pre class="playlist-instructions__text">{playlist.data.instructions}</pre>
  </section>

  <section class="playlist-journey" aria-label="Journey steps">
    <h2>Journey steps</h2>
    <ol class="playlist-journey__list">
      {resolved.map(({ item, entry }) => {
        const stationSlug = item.station_slug ?? entry!.slug;
        const stationHref = withBase(`stations/${stationSlug}/`);
        return (
          <li class="playlist-journey__item cp-card">
            <div class="playlist-journey__header">
              <h3>{entry!.data.title}</h3>
              <TagPill label={item.required ? "Required" : "Optional"} tone={item.required ? "teal" : "default"} />
            </div>
            <p class="playlist-journey__meta">{entry!.data.time_minutes} min</p>
            <p class="playlist-journey__goal">{item.goal}</p>
            {item.note && <p class="playlist-journey__note">{item.note}</p>}
            <div class="playlist-journey__actions">
              <a class="cp-button cp-button--primary" href={normalizeBasePathPath(entry!.data.demo_path, base)}>
                Play
              </a>
              {entry!.data.station_path ? (
                <a class="cp-button cp-button--ghost" href={stationHref}>
                  Station
                </a>
              ) : null}
              <a class="cp-button cp-button--ghost" href={withBase(`exhibits/${entry!.slug}/`)}>
                Exhibit page
              </a>
            </div>
          </li>
        );
      })}
    </ol>
  </section>

  <section class="playlist-why cp-prose" aria-label="Why this sequence">
    <h2>Why this sequence?</h2>
    <Content />
  </section>
</Layout>

<style>
  .playlist-header {
    display: grid;
    gap: var(--cp-space-2);
  }

  .playlist-header h1 {
    margin: 0;
    font-size: 1.9rem;
  }

  .playlist-header__goal {
    margin: 0;
    color: var(--cp-title-strong);
    font-size: var(--cp-text-lg);
  }

  .playlist-header__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--cp-space-3);
    margin-top: var(--cp-space-1);
  }

  .playlist-header__stat {
    display: inline-flex;
    align-items: baseline;
    gap: 4px;
  }

  .playlist-header__stat-value {
    font-family: var(--cp-font-mono);
    font-size: var(--cp-text-lg);
    font-weight: var(--cp-font-semibold);
    color: var(--cp-accent-amber);
  }

  .playlist-header__stat-unit {
    font-size: var(--cp-text-sm);
    color: var(--cp-accent-ice);
  }

  .playlist-header__overview {
    margin: 0;
    color: var(--cp-text2);
    max-width: 72ch;
  }

  .playlist-header__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .playlist-header__actions .cp-button {
    font-size: var(--cp-text-sm);
    padding: 6px 10px;
  }

  .playlist-instructions,
  .playlist-journey,
  .playlist-why {
    margin-top: var(--cp-space-5);
  }

  .playlist-instructions h2,
  .playlist-journey h2,
  .playlist-why h2 {
    margin: 0 0 var(--cp-space-3);
  }

  .playlist-instructions__text {
    margin: 0;
    padding: var(--cp-space-4);
    border-radius: var(--cp-r-2);
    background: var(--cp-bg1);
    border: 1px solid var(--cp-border);
    color: var(--cp-text);
    white-space: pre-wrap;
    font-family: var(--cp-font-mono);
    font-size: var(--cp-text-sm);
    line-height: 1.6;
  }

  .playlist-journey__list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: var(--cp-space-3);
  }

  .playlist-journey__item {
    padding: var(--cp-space-4);
    display: grid;
    gap: var(--cp-space-2);
  }

  .playlist-journey__header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--cp-space-2);
  }

  .playlist-journey__header h3 {
    margin: 0;
  }

  .playlist-journey__meta,
  .playlist-journey__note {
    margin: 0;
    color: var(--cp-text2);
    font-size: var(--cp-text-sm);
  }

  .playlist-journey__goal {
    margin: 0;
    color: var(--cp-text);
    font-size: var(--cp-text-sm);
  }

  .playlist-journey__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .playlist-journey__actions .cp-button {
    font-size: var(--cp-text-sm);
    padding: 6px 10px;
  }
</style>
