---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import TagPill from "../../components/TagPill.astro";
import DemoIllustration from "../../components/DemoIllustration.astro";
import { normalizeBasePathPath } from "../../lib/catalog";

const playlists = await getCollection("playlists");
const demos = await getCollection("demos");

const base = import.meta.env.BASE_URL;
const withBase = (path: string) => normalizeBasePathPath(path, base);

const demoFilterSlug = Astro.url.searchParams.get("demo")?.trim() ?? "";
const filteredPlaylists = demoFilterSlug
  ? playlists.filter((playlist) =>
      playlist.data.demos.some((demo) => demo.slug === demoFilterSlug)
    )
  : playlists;

const demoBySlug = new Map<string, (typeof demos)[number]>(
  demos.map((demo) => [demo.slug, demo] as [string, (typeof demos)[number]])
);
const demoFilterTitle = demoFilterSlug
  ? demoBySlug.get(demoFilterSlug)?.data.title ?? demoFilterSlug
  : "";

const groups = [
  { key: "lecture", title: "For Astro 101 lectures" },
  { key: "lab", title: "For inquiry labs (Station mode)" },
  { key: "self-study", title: "For self-study" },
  { key: "instructor", title: "For instructors (modules)" }
] as const;

const grouped = groups.map((group) => ({
  ...group,
  playlists: filteredPlaylists.filter((playlist) => playlist.data.use_case === group.key)
}));
---

<Layout title="Playlists — Cosmic Playground">
  <Breadcrumb crumbs={[{ label: "Playlists" }]} withBase={withBase} />

  <section class="playlist-hero cp-hero">
    <h1>Playlists</h1>
    <p class="playlist-hero__identity">An interactive museum of astronomy reasoning instruments.</p>
    <p class="playlist-hero__identity-sub">
      Explore observables, models, and inferences—like doing experiments on ideas.
    </p>
    <p class="playlist-hero__lede">Curated concept journeys you can assign or work through in order.</p>
    <div class="playlist-hero__actions">
      <a class="cp-button cp-button--ghost" href={withBase("explore/")}>Back to Explore</a>
    </div>
  </section>

  {demoFilterSlug ? (
    <section class="playlist-filter-note cp-card" role="status" aria-live="polite">
      <p>
        Showing playlists containing <strong>{demoFilterTitle}</strong>.
      </p>
      <a href={withBase("playlists/")}>Clear filter</a>
    </section>
  ) : null}

  {grouped.map((group) =>
    group.playlists.length > 0 ? (
      <section class="playlist-group" aria-label={group.title}>
        <h2>{group.title}</h2>
        <div class="playlist-grid">
          {group.playlists.map((playlist) => {
            const requiredCount = playlist.data.demos.filter((d) => d.required).length;
            const previewDemos = playlist.data.demos
              .slice(0, 3)
              .map((demo) => ({ config: demo, entry: demoBySlug.get(demo.slug) }))
              .filter((item) => item.entry);

            return (
              <article
                class="playlist-card cp-card"
                id={playlist.data.anchor}
              >
                <div class="playlist-card__header">
                  <h3 class="playlist-card__title">{playlist.data.title}</h3>
                  <TagPill
                    label={`Level ${playlist.data.intended_level.toUpperCase()}`}
                    tone="blue"
                  />
                </div>

                <p class="playlist-card__goal">{playlist.data.learning_goal}</p>
                <p class="playlist-card__desc">{playlist.data.overview}</p>

                <div class="playlist-card__stats">
                  <span class="playlist-card__stat">
                    <span class="playlist-card__stat-value">{playlist.data.demos.length}</span>
                    <span class="playlist-card__stat-unit">demos</span>
                  </span>
                  <span class="playlist-card__stat">
                    <span class="playlist-card__stat-value">~{playlist.data.estimated_minutes}</span>
                    <span class="playlist-card__stat-unit">min</span>
                  </span>
                  <span class="playlist-card__stat">
                    <span class="playlist-card__stat-value">{requiredCount}</span>
                    <span class="playlist-card__stat-unit">required</span>
                  </span>
                </div>

                <ul class="playlist-card__preview" aria-label="Demo preview">
                  {previewDemos.map((item) => (
                    <li>
                      <span class="playlist-card__preview-icon" aria-hidden="true">
                        <DemoIllustration slug={item.entry!.slug} />
                      </span>
                      <span>{item.entry!.data.title}</span>
                    </li>
                  ))}
                </ul>

                <div class="playlist-card__actions">
                  <a class="cp-button cp-button--primary" href={withBase(`playlists/${playlist.slug}/`)}>
                    Open playlist
                  </a>
                  <a class="cp-button cp-button--ghost" href={withBase("explore/")}>Browse demos</a>
                </div>
              </article>
            );
          })}
        </div>
      </section>
    ) : null
  )}
</Layout>

<style>
  .playlist-hero {
    margin-bottom: var(--cp-space-5);
    display: grid;
    gap: var(--cp-space-2);
  }

  .playlist-hero__identity {
    margin: 0;
    color: var(--cp-title-strong);
    font-weight: var(--cp-font-semibold);
    font-size: var(--cp-text-lg);
    max-width: 72ch;
  }

  .playlist-hero__identity-sub {
    margin: 0;
    color: var(--cp-text2);
    max-width: 72ch;
  }

  .playlist-hero__lede {
    margin: 0;
    color: var(--cp-muted);
    max-width: 72ch;
  }

  .playlist-hero__actions {
    margin-top: var(--cp-space-2);
  }

  .playlist-filter-note {
    margin-bottom: var(--cp-space-5);
    padding: var(--cp-space-3);
    display: flex;
    flex-wrap: wrap;
    gap: var(--cp-space-3);
    align-items: center;
    justify-content: space-between;
  }

  .playlist-filter-note p {
    margin: 0;
    color: var(--cp-text2);
  }

  .playlist-group {
    margin-top: var(--cp-space-6);
  }

  .playlist-group h2 {
    margin: 0 0 var(--cp-space-4);
  }

  .playlist-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: var(--cp-space-4);
  }

  .playlist-card {
    padding: var(--cp-space-4);
    display: grid;
    gap: var(--cp-space-3);
  }

  .playlist-card__header {
    display: flex;
    flex-wrap: wrap;
    gap: var(--cp-space-2);
    align-items: center;
    justify-content: space-between;
  }

  .playlist-card__title {
    margin: 0;
    color: var(--cp-title);
    font-size: var(--cp-text-xl);
  }

  .playlist-card__goal {
    margin: 0;
    color: var(--cp-text);
    font-size: var(--cp-text-sm);
  }

  .playlist-card__desc {
    margin: 0;
    color: var(--cp-text2);
    font-size: var(--cp-text-sm);
  }

  .playlist-card__stats {
    display: flex;
    flex-wrap: wrap;
    gap: var(--cp-space-3);
  }

  .playlist-card__stat {
    display: inline-flex;
    gap: 4px;
    align-items: baseline;
  }

  .playlist-card__stat-value {
    font-family: var(--cp-font-mono);
    font-weight: var(--cp-font-semibold);
    color: var(--cp-accent-amber);
  }

  .playlist-card__stat-unit {
    font-size: var(--cp-text-sm);
    color: var(--cp-accent-ice);
  }

  .playlist-card__preview {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: var(--cp-space-2);
  }

  .playlist-card__preview li {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: var(--cp-space-2);
    align-items: center;
    font-size: var(--cp-text-sm);
    color: var(--cp-text2);
  }

  .playlist-card__preview-icon {
    width: 28px;
    border: 1px solid var(--cp-border-subtle);
    border-radius: var(--cp-r-1);
    overflow: clip;
  }

  .playlist-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .playlist-card__actions .cp-button {
    font-size: var(--cp-text-sm);
    padding: 6px 10px;
  }
</style>
